<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sweet Layers Bakery</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">Sweet Layers</div>
    <button class="hamburger" id="hamburger">&#9776;</button>
    <ul class="nav-links" id="nav-links">
      <li><a href="/" class="active">Home</a></li>
      <li><a href="/menu">Menu</a></li>
      <li><a href="/products">Products</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero-content">
      <h1>Fresh Cakes &amp; Bakes</h1>
      <p>Homemade with love, delivered to your door.</p>
      <a href="/menu" class="btn">See Our Menu</a>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="features">
    <h2>Why Choose Sweet Layers?</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🌿</div>
        <h3>100% Natural</h3>
        <p>No preservatives, no artificial colours. Only fresh, natural ingredients in every bake.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎂</div>
        <h3>Custom Orders</h3>
        <p>Want something unique? We create fully customised cakes for birthdays, weddings & events.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🚚</div>
        <h3>Home Delivery</h3>
        <p>Fresh bakes delivered right to your door across Lahore. Same-day delivery available.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">❤️</div>
        <h3>Made with Love</h3>
        <p>Every order is baked fresh to order — never sitting on a shelf waiting to be sold.</p>
      </div>
    </div>
  </section>

  <!-- FEATURED ITEMS PREVIEW -->
  <section class="featured">
    <h2>Customer Favourites</h2>
    <p class="section-sub">A taste of what we do best</p>
    <div class="menu-grid">
      <div class="card">
        <img src="/images/strawberry cake.png" alt="Strawberry Cake" />
        <h3>Classic Strawberry Cake</h3>
        <p>Strawberry sponge with fresh cream.</p>
        <span>Rs. 1,800</span>
      </div>
      <div class="card">
        <img src="/images/choco cake.png" alt="Chocolate Cake" />
        <h3>Chocolate Fudge Cake</h3>
        <p>Rich dark chocolate with fudge frosting.</p>
        <span>Rs. 2,200</span>
      </div>
      <div class="card">
        <img src="/images/cupcake.png" alt="Cupcakes" />
        <h3>Cupcakes (Box of 12)</h3>
        <p>Fluffy cupcakes with buttercream swirls.</p>
        <span>Rs. 1,200</span>
      </div>
    </div>
    <div class="view-all-wrap">
      <a href="/menu" class="btn">View Full Menu</a>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <h2>What Our Customers Say</h2>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <p>"The birthday cake was absolutely stunning and tasted even better than it looked. Will definitely order again!"</p>
        <h4>— Ayesha R., Gulberg</h4>
      </div>
      <div class="testimonial-card">
        <p>"Ordered cupcakes for my office party and everyone was asking where they came from. Highly recommended!"</p>
        <h4>— Bilal K., DHA</h4>
      </div>
      <div class="testimonial-card">
        <p>"Sweet Layers made our wedding cake exactly as we imagined. So professional and so delicious."</p>
        <h4>— Sana & Omar, Lahore</h4>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <h2>Ready to Place an Order?</h2>
    <p>Get in touch and we'll bake something special just for you.</p>
    <a href="/contact" class="btn btn-light">Contact Us</a>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <p>&copy; 2025 Sweet Layers Bakery. All rights reserved.</p>
  </footer>

  <script src="/js/script.js"></script>
</body>
</html>
