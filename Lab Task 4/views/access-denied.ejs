<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Access Denied – Sweet Layers Bakery</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="logo">Sweet Layers</div>
    <button class="hamburger" id="hamburger">&#9776;</button>
    <ul class="nav-links" id="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/menu">Menu</a></li>
      <li><a href="/products">Products</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
      <% if (userId) { %>
        <% if (userRole === "admin") { %>
          <li><a href="/admin">Admin Panel</a></li>
        <% } %>
        <li><a href="/profile"><%= userName %></a></li>
        <li><a href="/logout">Logout</a></li>
      <% } else { %>
        <li><a href="/login">Login</a></li>
        <li><a href="/register">Register</a></li>
      <% } %>
    </ul>
  </nav>


  <!-- ERROR SECTION -->
  <section class="contact" style="padding: 100px 20px;">
    <div style="text-align: center; max-width: 600px; margin: 0 auto;">
      <h1 style="color: #c0586a; font-size: 3rem; margin-bottom: 20px;">⛔ 403</h1>
      <h2 style="color: #5c3317; margin-bottom: 20px;">Access Denied</h2>
      <p style="font-size: 1.1rem; color: #666; margin-bottom: 30px;">
        <%= message %>
      </p>
      <p style="color: #888; margin-bottom: 30px;">
        Only administrators can access this page. If you believe this is an error, please contact support.
      </p>
      <a href="/" class="btn" style="background-color: #c0586a; color: #fff; padding: 12px 30px; border-radius: 6px; text-decoration: none; display: inline-block;">
        Go Back Home
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <p>&copy; 2025 Sweet Layers Bakery. All rights reserved.</p>
  </footer>

  <script src="/js/script.js"></script>
</body>
</html>