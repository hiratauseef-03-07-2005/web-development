<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard - Sweet Layers</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/admin-style.css">
</head>
<body>

  <nav class="navbar">
  <div class="logo">Sweet Layers</div>
  <button class="hamburger" id="hamburger">&#9776;</button>
  <ul class="nav-links" id="nav-links">
    <li><a href="/" class="active">Home</a></li>
    <li><a href="/menu">Menu</a></li>
    <li><a href="/products">Products</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
    <% if (userId) { %>
      <% if (userRole === "admin") { %>
        <li><a href="/admin">Admin Panel</a></li>
      <% } %>
      <li><a href="/profile"><%= userName %></a></li>
      <li><a href="/logout">Logout</a></li>
    <% } else { %>
      <li><a href="/login">Login</a></li>
      <li><a href="/register">Register</a></li>
    <% } %>
  </ul>
</nav>

<!-- FLASH MESSAGES -->
<% if (messages.error && messages.error.length > 0) { %>
  <div style="max-width: 600px; margin: 20px auto;">
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error"><%= msg %></div>
    <% }); %>
  </div>
<% } %>
<% if (messages.success && messages.success.length > 0) { %>
  <div style="max-width: 600px; margin: 20px auto;">
    <% messages.success.forEach(msg => { %>
      <div class="alert alert-success"><%= msg %></div>
    <% }); %>
  </div>
<% } %>

  <div class="admin-container">
    <div class="admin-header">
      <h1>Admin Dashboard</h1>
      <a href="/admin/add-product" class="btn-add">+ Add New Product</a>
    </div>

    <table>
      <thead>
        <tr>
          <th>Product Name</th>
          <th>Category</th>
          <th>Price (Rs)</th>
          <th>Stock</th>
          <th>Rating</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(product => { %>
          <tr>
            <td><%= product.name %></td>
            <td><%= product.category %></td>
            <td><%= product.price %></td>
            <td><%= product.stock %></td>
            <td><%= product.rating %>/5</td>
            <td>
              <a href="/admin/edit-product/<%= product._id %>" class="btn-edit">Edit</a>
              <button class="btn-delete" onclick="deleteProduct('<%= product._id %>', '<%= product.name %>')">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <a href="/" class="back-link">← Back to Home</a>
  </div>

  <script>
    function deleteProduct(productId, productName) {
      if (confirm(`Are you sure you want to delete "${productName}"?`)) {
        // Create a form and submit it
        let form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/delete-product/' + productId;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
  <script src="/js/script.js"></script>
</body>
</html>
