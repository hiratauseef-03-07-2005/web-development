<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products – Sweet Layers Bakery</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
  <div class="logo">Sweet Layers</div>
  <button class="hamburger" id="hamburger">&#9776;</button>
  <ul class="nav-links" id="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/menu">Menu</a></li>
    <li><a href="/products"class="active">Products</a></li>
    <li><a href="/onsale-products">On Sale 🏷️</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/contact">Contact</a></li>
    <% if (userId) { %>
      <% if (userRole === "admin") { %>
        <li><a href="/admin">Admin Panel</a></li>
      <% } %>
      <li><a href="/profile"><%= userName %></a></li>
      <li><a href="/logout">Logout</a></li>
    <% } else { %>
      <li><a href="/login">Login</a></li>
      <li><a href="/register">Register</a></li>
    <% } %>
  </ul>
</nav>

<!-- FLASH MESSAGES -->
<% if (messages.error && messages.error.length > 0) { %>
  <div style="max-width: 600px; margin: 20px auto;">
    <% messages.error.forEach(msg => { %>
      <div class="alert alert-error"><%= msg %></div>
    <% }); %>
  </div>
<% } %>
<% if (messages.success && messages.success.length > 0) { %>
  <div style="max-width: 600px; margin: 20px auto;">
    <% messages.success.forEach(msg => { %>
      <div class="alert alert-success"><%= msg %></div>
    <% }); %>
  </div>
<% } %>


  <!-- PAGE HEADER -->
  <section class="page-header">
    <h1>All Products</h1>
    <p>Browse our full catalog — filter by category, price, or search by name.</p>
    <p class="products-count"><%= totalProducts %> product<%= totalProducts !== 1 ? 's' : '' %> found</p>
  </section>

  <!-- FILTER BAR -->
  <section class="filter-section">
    <form class="filter-form" action="/products" method="GET">

      <!-- SEARCH -->
      <div class="filter-group">
        <label for="search">Search</label>
        <input
          type="text"
          id="search"
          name="search"
          placeholder="e.g. chocolate cake..."
          value="<%= search %>"
        />
      </div>

      <!-- CATEGORY -->
      <div class="filter-group">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">All Categories</option>
          <% categories.forEach(function(cat) { %>
            <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>>
              <%= cat %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- MIN PRICE -->
      <div class="filter-group">
        <label for="minPrice">Min Price (Rs.)</label>
        <input
          type="number"
          id="minPrice"
          name="minPrice"
          placeholder="e.g. 500"
          value="<%= minPrice %>"
          min="0"
        />
      </div>

      <!-- MAX PRICE -->
      <div class="filter-group">
        <label for="maxPrice">Max Price (Rs.)</label>
        <input
          type="number"
          id="maxPrice"
          name="maxPrice"
          placeholder="e.g. 3000"
          value="<%= maxPrice %>"
          min="0"
        />
      </div>

      <!-- BUTTONS -->
      <div class="filter-buttons">
        <button type="submit" class="btn">Apply Filters</button>
        <a href="/products" class="btn btn-outline">Clear</a>
      </div>

    </form>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="products-section">
    <% if (products.length === 0) { %>
      <div class="no-results">
        <p>No products found matching your filters.</p>
        <a href="/products" class="btn">Clear Filters</a>
      </div>
    <% } else { %>
      <div class="products-grid">
        <% products.forEach(function(product) { %>
          <div class="product-card">
            <div class="product-img-wrap">
              <img src="<%= product.image %>" alt="<%= product.name %>" />
              <span class="product-category"><%= product.category %></span>
            </div>
            <div class="product-info">
              <h3><%= product.name %></h3>
              <p><%= product.description %></p>
              <div class="product-meta">
                <div class="product-rating">
                  <!-- Render stars based on rating -->
                  <% for(let i = 1; i <= 5; i++) { %>
                    <% if(i <= Math.floor(product.rating)) { %>
                      <span class="star filled">★</span>
                    <% } else { %>
                      <span class="star">★</span>
                    <% } %>
                  <% } %>
                  <span class="rating-num">(<%= product.rating %>)</span>
                </div>
                <span class="stock-badge <%= product.stock <= 5 ? 'low-stock' : 'in-stock' %>">
                  <%= product.stock <= 5 ? 'Only ' + product.stock + ' left' : 'In Stock' %>
                </span>
              </div>
              <div class="product-footer">
                <span class="product-price">Rs. <%= product.price.toLocaleString() %></span>
                <a href="/contact" class="btn btn-sm">Order Now</a>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </section>

  <!-- PAGINATION -->
  <% if (totalPages > 1) { %>
    <section class="pagination-section">
      <div class="pagination">

        <!-- PREVIOUS button -->
        <% if (currentPage > 1) { %>
          <a href="/products?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
             class="page-btn">
            &laquo; Previous
          </a>
        <% } else { %>
          <span class="page-btn disabled">&laquo; Previous</span>
        <% } %>

        <!-- PAGE NUMBER BUTTONS -->
        <% for (let i = 1; i <= totalPages; i++) { %>
          <a href="/products?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
             class="page-btn <%= currentPage === i ? 'active-page' : '' %>">
            <%= i %>
          </a>
        <% } %>

        <!-- NEXT button -->
        <% if (currentPage < totalPages) { %>
          <a href="/products?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
             class="page-btn">
            Next &raquo;
          </a>
        <% } else { %>
          <span class="page-btn disabled">Next &raquo;</span>
        <% } %>

      </div>
      <p class="pagination-info">
        Page <%= currentPage %> of <%= totalPages %> &nbsp;|&nbsp; Showing <%= products.length %> of <%= totalProducts %> products
      </p>
    </section>
  <% } %>

  <!-- FOOTER -->
  <footer class="footer">
    <p>&copy; 2025 Sweet Layers Bakery. All rights reserved.</p>
  </footer>

  <script src="/js/script.js"></script>
</body>
</html>
