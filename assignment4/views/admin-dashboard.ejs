<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard - Sweet Layers</title>
  <link rel="stylesheet" href="/admin-style.css">
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>Admin Dashboard</h1>
      <a href="/admin/add-product" class="btn-add">+ Add New Product</a>
    </div>

    <table>
      <thead>
        <tr>
          <th>Product Name</th>
          <th>Category</th>
          <th>Price (Rs)</th>
          <th>Stock</th>
          <th>Rating</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(product => { %>
          <tr>
            <td><%= product.name %></td>
            <td><%= product.category %></td>
            <td><%= product.price %></td>
            <td><%= product.stock %></td>
            <td><%= product.rating %>/5</td>
            <td>
              <a href="/admin/edit-product/<%= product._id %>" class="btn-edit">Edit</a>
              <button class="btn-delete" onclick="deleteProduct('<%= product._id %>', '<%= product.name %>')">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <a href="/" class="back-link">← Back to Home</a>
  </div>

  <script>
    function deleteProduct(productId, productName) {
      if (confirm(`Are you sure you want to delete "${productName}"?`)) {
        // Create a form and submit it
        let form = document.createElement('form');
        form.method = 'POST';
        form.action = '/admin/delete-product/' + productId;
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>
</html>
